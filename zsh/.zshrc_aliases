alias ..='cd .. && /bin/lsd -lah --group-dirs=first'
alias ...='cd ../.. && /bin/lsd -lah --group-dirs=first'
alias ....='cd ../../.. && /bin/lsd -lah --group-dirs=first'
alias .....='cd ../../../.. && /bin/lsd -lah --group-dirs=first'
alias composefiles='cd /srv/docker/compose && /bin/lsd -lah --group-dirs=first'
alias srv='cd /srv && /bin/lsd -lah --group-dirs=first'

alias ls='/bin/lsd --group-dirs=first'
alias ll='/bin/lsd -lah --group-dirs=first'
alias la='/bin/lsd -a --group-dirs=first'
alias lt='/bin/lsd --tree --group-dirs=first'

alias cat='/bin/batcat --paging=never'
alias bat='/bin/batcat'
alias grep='/bin/grep --color=auto'

alias df='/bin/df -h'
alias du='/bin/du -h'

alias update='sudo apt-get update && sudo apt-get upgrade -y'

alias ports='/bin/ss -tulpen'

alias myip='/bin/curl ifconfig.me'

alias weather='/bin/curl wttr.in'

alias please='sudo $(fc -ln -1)'

alias cls='clear'

alias reload='source ~/.zshrc'

alias moshu-ipscan="~/scripts/moshu-ipscan"