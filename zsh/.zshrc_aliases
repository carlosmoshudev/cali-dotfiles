alias ..='cd .. && lsd -lah --group-dirs=first'
alias ...='cd ../.. && lsd -lah --group-dirs=first'
alias ....='cd ../../.. && lsd -lah --group-dirs=first'
alias .....='cd ../../../.. && lsd -lah --group-dirs=first'
alias composefiles='cd /srv/docker/compose && lsd -lah --group-dirs=first'
alias srv='cd /srv && lsd -lah --group-dirs=first'

alias ls='lsd --group-dirs=first'
alias ll='lsd -lah --group-dirs=first'
alias la='lsd -a --group-dirs=first'
alias lt='lsd --tree --group-dirs=first'

alias cat='batcat --paging=never'
alias bat='batcat'
alias grep='grep --color=auto'

alias df='df -h'
alias du='du -h'

alias update='sudo apt-get update && sudo apt-get upgrade -y'

alias ports='ss -tulpen'

alias myip='curl ifconfig.me'

alias weather='curl wttr.in'

alias please='sudo $(fc -ln -1)'

alias cls='clear'

alias reload='source ~/.zshrc'

alias moshu-ipscan="$HOME/scripts/moshu-ipscan"